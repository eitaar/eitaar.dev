---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import avatar from '../../../assets/img/avatar.webp';
import AboutJSX from '../jsx/AboutJSX';
---

<AboutJSX client:visible>
  <Image
    src={avatar}
    alt="Avatar"
    slot="avatarImg"
    width={300}
    loading="eager"
    fetchpriority="high"
    decoding="async"
    format="avif"
    quality={40}
    class="w-40 rounded-full border-2 border-slate-200 bg-transparent shadow-lg lg:w-50"
  />
  <Icon name="ri:twitter-x-fill" slot="xIcon" class="h-7 w-7" />
  <Icon name="ri:github-fill" slot="githubIcon" class="h-7 w-7" />
  <Icon name="ri:discord-fill" slot="discordIcon" class="h-7 w-7 text-[#5662f6]" />
</AboutJSX>
