---
import { Icon } from 'astro-icon/components';
import HobbiesComponent from '../jsx/Hobbies';
import hobbies from '../../../data/hobbies';
---

<HobbiesComponent hobbies={hobbies}>
  <Icon name="mdi:gamepad-variant-outline" slot="hobbyIcon" class="h-7 w-auto" />
  <Icon name="mdi:minecraft" slot="hobbyIcon0" class="h-8 w-8 text-[#52a535]" />
  <Icon name="simple-icons:undertale" slot="hobbyIcon1" class="h-8 w-8 text-[#e71d29]" />
  <Icon name="twemoji:mahjong-red-dragon" slot="hobbyIcon2" class="h-8 w-8" />
  <Icon name="mdi:book-open-variant" slot="hobbyIcon3" class="h-8 w-8" />
  <Icon name="devicon:vscode" slot="hobbyIcon4" class="h-8 w-8" />
</HobbiesComponent>
