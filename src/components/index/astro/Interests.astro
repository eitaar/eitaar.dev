---
import { Icon } from 'astro-icon/components';
import InterestsJSX from '../jsx/InterestsJSX';
---

<InterestsJSX>
  <Icon name="mdi:star-outline" class="h-7 w-auto" slot="interestIcon" />
  <Icon name="devicon:arduino" class="h-10 w-auto xl:h-12" slot="ardIcon" />
  <Icon name="devicon:cplusplus" class="h-10 w-auto xl:h-12" slot="cppIcon" />
  <Icon
    name="devicon:rust"
    class="h-10 w-auto fill-black xl:h-12 dark:fill-white"
    slot="rustIcon"
  />
  <Icon name="devicon:blender" class="h-10 w-auto xl:h-12" slot="bderIcon" />
  <Icon name="devicon:flutter" class="h-10 w-auto xl:h-12" slot="fltIcon" />
  <Icon name="devicon:java" class="h-10 w-auto xl:h-12" slot="javaIcon" />
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="h-10 w-auto fill-[#ee2663] xl:h-12"
    viewBox="0 0 28 28"
    slot="p5Icon"
  >
    <path
      d="M16.909,10.259l8.533-2.576l1.676,5.156l-8.498,2.899l5.275,7.48l-4.447,3.225l-5.553-7.348L8.487,26.25l-4.318-3.289l5.275-7.223L0.88,12.647l1.678-5.16l8.598,2.771V1.364h5.754V10.259z"
    ></path>
  </svg>
  <Icon
    name="devicon:threejs"
    class="h-10 w-auto fill-black xl:h-12 dark:fill-white"
    slot="thjsIcon"
  />
  <Icon name="devicon:react" class="h-10 w-auto xl:h-12" slot="reactIcon" />
</InterestsJSX>
