---
import type { StatsData, Language, PieChartSlice } from '../../../types/common';
import { Icon } from 'astro-icon/components';
import StatsComponent from '../jsx/Stats';
import { fetcher } from '../../../assets/src/fetcher';

const statsData: StatsData = await fetcher();
// Prepare data for pie chart
const starsData: PieChartSlice[] = statsData.data.languages.map((lang) => ({
  name: lang.name,
  value: lang.size,
  color: lang.color,
}));
---

<StatsComponent statsData={statsData}>
  <Icon name="mdi:graph-box" class="h-7 w-auto" />
</StatsComponent>
