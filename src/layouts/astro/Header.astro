---
import HeaderJSX from '../jsx/HeaderJSX';
import { Icon } from 'astro-icon/components';
---

<HeaderJSX client:load>
  <Icon name="mdi:theme-light-dark" class="h-8 w-8" slot="themeToggle" />
  <Icon name="mdi:umbrella-closed-variant" class="h-8 w-8" slot="rainToggleOff" />
  <Icon name="mdi:umbrella" class="h-8 w-8" slot="rainToggleOn" />
</HeaderJSX>
